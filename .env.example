# TMDB API Key — get one free at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Firebase (same project as AniWeb is fine — just a different app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public deployed MoviWeb URL used for Firebase Auth email redirects.
# Example: https://moviweb-stream.vercel.app
VITE_PUBLIC_SITE_URL=

# Optional: only set this if you configured a custom Firebase Hosting link domain.
VITE_FIREBASE_AUTH_LINK_DOMAIN=
